---
const bullets = [
  'Astro dev runs entirely inside BrowserPod.',
  'The recipe uses the passthrough image service to avoid depending on image processing.',
  'BrowserPod exposes the local server through a public portal URL that this page is loaded from.',
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Astro on BrowserPod</title>
    <style>
      :root {
        color-scheme: light;
        font-family: "Avenir Next", "Segoe UI", sans-serif;
        color: #24191f;
        background:
          radial-gradient(circle at top center, rgba(255, 111, 82, 0.22), transparent 28%),
          linear-gradient(180deg, #fff8f8 0%, #f1e4f0 100%);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
      }

      main {
        min-height: 100vh;
        padding: 2rem;
      }

      section,
      article {
        border-radius: 1.4rem;
        border: 1px solid rgba(36, 25, 31, 0.08);
        background: rgba(255, 255, 255, 0.84);
        box-shadow: 0 24px 36px rgba(36, 25, 31, 0.08);
      }

      section {
        padding: 2rem;
      }

      .eyebrow {
        margin: 0 0 0.75rem;
        color: #d15433;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 0.78rem;
        font-weight: 700;
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 8vw, 4rem);
        line-height: 0.95;
      }

      .lede,
      article p {
        color: #645867;
        line-height: 1.7;
      }

      .lede {
        max-width: 42rem;
        margin-top: 1rem;
      }

      .grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
        margin-top: 1rem;
      }

      article {
        padding: 1.3rem;
      }

      article h2 {
        margin: 0 0 0.75rem;
        font-size: 1rem;
      }
    </style>
  </head>
  <body>
    <main>
      <section>
        <p class="eyebrow">Astro recipe</p>
        <h1>Hello from BrowserPod</h1>
        <p class="lede">
          Astro is serving this page from inside BrowserPod. The surrounding
          recipe runner copies this project into the pod, installs dependencies,
          and then opens the portal URL in an iframe.
        </p>
      </section>

      <div class="grid">
        {bullets.map((bullet) => (
          <article>
            <h2>What this demo proves</h2>
            <p>{bullet}</p>
          </article>
        ))}
      </div>
    </main>
  </body>
</html>
